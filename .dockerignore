# keep build context small; everything below is rebuilt or mounted at runtime
.git
.gitignore
.gitattributes
.dockerignore
Dockerfile
docker-compose.yml
README.md
README*.md
start.bat
start.ps1
start.sh

# user data — must come from a volume, never baked into the image
.env
data/

# dev artefacts
node_modules/
**/node_modules/
**/.venv/
**/__pycache__/
**/*.pyc
.pytest_cache/

# frontend gets rebuilt inside the image
frontend/dist/
frontend/.vite/
frontend/tsconfig.tsbuildinfo
frontend/tsconfig.node.tsbuildinfo

# editor / OS noise
.idea/
.vscode/
.DS_Store
.claude/
